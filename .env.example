# ── Node.js API ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# PostgreSQL — Neon.tech free tier (https://neon.tech) or local Docker
DATABASE_URL=postgresql://user:password@host:5432/devtrack
# Or use individual vars instead of DATABASE_URL:
# DB_USER=
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=devtrack

# Redis — Upstash free tier (https://upstash.com) or local Docker
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change_me_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=1h

# Python agents microservice
AGENTS_SERVICE_URL=http://localhost:8000

# ─────────────────────────────────────────────────────────────
# agents/.env — create this separate file (NEVER commit)
# ─────────────────────────────────────────────────────────────
#
# Pick ONE LLM provider — all are free tier:
#
# Option 1: Groq (RECOMMENDED — fast, free, no credit card)
#   Sign up at https://console.groq.com and get an API key
#   LLM_PROVIDER=groq
#   GROQ_API_KEY=gsk_...
#   GROQ_MODEL=llama-3.3-70b-versatile
#
# Option 2: Google Gemini (free tier, generous limits)
#   Sign up at https://aistudio.google.com/apikey
#   LLM_PROVIDER=gemini
#   GOOGLE_API_KEY=...
#   GEMINI_MODEL=gemini-1.5-flash
#
# Option 3: Ollama (fully local, fully free, no internet needed)
#   Install from https://ollama.com, then `ollama pull llama3.1:8b`
#   LLM_PROVIDER=ollama
#   OLLAMA_BASE_URL=http://localhost:11434
#   OLLAMA_MODEL=llama3.1:8b
#
# LOG_LEVEL=INFO
